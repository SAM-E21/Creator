
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información del perfil de un usuario registrado.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "position": { "type": "string" },
        "plan": { "type": "string", "enum": ["Gratuito", "Pro"] }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Proyecto",
      "description": "Un espacio de trabajo para un proyecto específico.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "shareCode": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "progress": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "members", "name"]
    },
    "Task": {
      "title": "Tarea",
      "description": "Una tarea o subtarea dentro de un proyecto.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "content": { "type": "string" },
        "completed": { "type": "boolean" },
        "subtasks": { "type": "array", "items": { "$ref": "#/entities/Task" } },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "projectId", "content", "completed"]
    },
    "ProjectTable": {
      "title": "Tabla de Proyecto",
      "description": "Una tabla de datos personalizada dentro de un proyecto.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "data": { "type": "object" },
        "columnWidths": { "type": "array", "items": { "type": "number" } },
        "updatedAt": { "type": "object" }
      },
      "required": ["projectId", "name", "type", "data"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfiles de usuario."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Documentos de proyecto."
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tareas del proyecto."
    },
    "/projects/{projectId}/tables/{tableId}": {
      "schema": "ProjectTable",
      "description": "Tablas del proyecto."
    }
  }
}
